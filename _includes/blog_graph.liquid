{% comment %}
  Blog graph widget — interactive D3 force-directed graph of posts connected by tags/categories.
  Include this at the top of the blog page content.
{% endcomment %}

{% comment %} Collect unique tags and categories across all posts {% endcomment %}
{% assign all_tags = "" | split: "" %}
{% assign all_categories = "" | split: "" %}
{% for post in site.posts %}
  {% for tag in post.tags %}
    {% unless all_tags contains tag %}
      {% assign all_tags = all_tags | push: tag %}
    {% endunless %}
  {% endfor %}
  {% for category in post.categories %}
    {% unless all_categories contains category %}
      {% assign all_categories = all_categories | push: category %}
    {% endunless %}
  {% endfor %}
{% endfor %}

<div id="blog-graph-widget" class="card mb-4 p-3">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <h6 class="card-title mb-0">
      <i class="fa-solid fa-sitemap fa-sm me-1"></i> Post Map
      <small class="text-muted ms-2" style="font-size:0.75rem; font-weight:normal;">drag &bull; scroll to zoom &bull; click to open</small>
    </h6>
    <button
      onclick="if(window.blogGraphFitToScreen) window.blogGraphFitToScreen()"
      class="btn btn-sm btn-outline-secondary"
      title="Fit all nodes into view"
    >
      <i class="fa-solid fa-expand fa-xs me-2"></i> Fit to screen
    </button>
  </div>
  <svg id="blog-graph" height="380" style="width:100%;display:block;border-radius:4px;"></svg>
</div>

<script>
window.blogGraphData = {
  nodes: [
    {% for post in site.posts %}
    {
      "id": {{ post.url | jsonify }},
      "type": "post",
      "title": {{ post.title | jsonify }},
      "nodename": {{ post.nodename | default: post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    {% if all_tags.size > 0 %},{% endif %}
    {% for tag in all_tags %}
    {
      "id": {{ tag | prepend: "tag:" | jsonify }},
      "type": "tag",
      "label": {{ tag | jsonify }},
      "url": {{ tag | slugify | prepend: "/blog/tag/" | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    {% if all_categories.size > 0 %},{% endif %}
    {% for category in all_categories %}
    {
      "id": {{ category | prepend: "cat:" | jsonify }},
      "type": "category",
      "label": {{ category | jsonify }},
      "url": {{ category | slugify | prepend: "/blog/category/" | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  links: [
    {% comment %} Collect unique category→tag pairs (inferred from posts that have both) {% endcomment %}
    {% assign cat_tag_seen = "" | split: "" %}
    {% for post in site.posts %}
      {% for category in post.categories %}
        {% for tag in post.tags %}
          {% assign pair = category | append: "|||" | append: tag %}
          {% unless cat_tag_seen contains pair %}
            {% assign cat_tag_seen = cat_tag_seen | push: pair %}
          {% endunless %}
        {% endfor %}
      {% endfor %}
    {% endfor %}
    {% assign first_link = true %}
    {% comment %} post → tag links {% endcomment %}
    {% for post in site.posts %}
      {% for tag in post.tags %}
        {% unless first_link %},{% endunless %}
        {% assign first_link = false %}
        { "source": {{ post.url | jsonify }}, "target": {{ tag | prepend: "tag:" | jsonify }} }
      {% endfor %}
    {% endfor %}
    {% comment %} category → tag links (inferred, deduplicated) {% endcomment %}
    {% for pair in cat_tag_seen %}
      {% assign parts = pair | split: "|||" %}
      {% unless first_link %},{% endunless %}
      {% assign first_link = false %}
      { "source": {{ parts[0] | prepend: "cat:" | jsonify }}, "target": {{ parts[1] | prepend: "tag:" | jsonify }} }
    {% endfor %}
    {% comment %} post → category fallback: only for posts with categories but no tags {% endcomment %}
    {% for post in site.posts %}
      {% if post.tags.size == 0 %}
        {% for category in post.categories %}
          {% unless first_link %},{% endunless %}
          {% assign first_link = false %}
          { "source": {{ post.url | jsonify }}, "target": {{ category | prepend: "cat:" | jsonify }} }
        {% endfor %}
      {% endif %}
    {% endfor %}
  ]
};
</script>

<script
  src="{{ site.third_party_libraries.d3.url.js }}"
  integrity="{{ site.third_party_libraries.d3.integrity.js }}"
  crossorigin="anonymous"
></script>
<script src="{{ '/assets/js/blog-graph.js' | relative_url }}"></script>
